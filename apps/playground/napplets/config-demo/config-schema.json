{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "demo-config napplet schema",
  "description": "Reference schema exercised by config-demo (v1.7 Phase 39 / D10)",
  "properties": {
    "theme": {
      "type": "string",
      "description": "UI theme token (e.g., 'dark', 'light')",
      "default": "dark"
    },
    "density": {
      "type": "string",
      "description": "UI density (e.g., 'compact', 'comfortable')",
      "default": "compact"
    },
    "notifications-enabled": {
      "type": "boolean",
      "description": "Whether notifications are enabled for this napplet",
      "default": true
    },
    "recentSearches": {
      "type": "array",
      "description": "Recent user searches (last 10, most-recent-first)",
      "items": { "type": "string" },
      "default": []
    }
  }
}
