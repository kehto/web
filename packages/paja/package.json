{
  "name": "@kehto/paja",
  "version": "0.6.8",
  "description": "Paja local authoring workshop for hosting napplets in a real Kehto iframe during development",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kehto/acl": "workspace:^",
    "@kehto/firewall": "workspace:^",
    "@kehto/nip": "workspace:^",
    "@kehto/runtime": "workspace:^",
    "@kehto/services": "workspace:^",
    "@kehto/shell": "workspace:^",
    "@kehto/wm": "workspace:^"
  },
  "peerDependencies": {
    "@napplet/core": ">=0.23.0 <=0.28.x",
    "@napplet/nap": ">=0.23.0 <=0.28.x",
    "nostr-tools": ">=2.23.3 <=2.x"
  },
  "devDependencies": {
    "@napplet/core": ">=0.23.0 <=0.28.x",
    "@napplet/nap": ">=0.23.0 <=0.28.x",
    "nostr-tools": "^2.23.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "cd ../.. && vitest run --config vitest.config.ts packages/paja",
    "test": "pnpm test:unit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kehto/web.git",
    "directory": "packages/paja"
  },
  "keywords": [
    "nostr",
    "napplet",
    "kehto",
    "paja",
    "workshop",
    "development",
    "runtime",
    "hmr"
  ]
}
