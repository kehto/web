{
  "name": "@kehto/nip",
  "version": "0.4.0",
  "description": "Tree-shakable bundle of unique Nostr NIP utilities for napplet runtimes — each NIP at its own subpath (e.g. @kehto/nip/66)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./5a": {
      "types": "./dist/5a/index.d.ts",
      "import": "./dist/5a/index.js"
    },
    "./5d": {
      "types": "./dist/5d/index.d.ts",
      "import": "./dist/5d/index.js"
    },
    "./51": {
      "types": "./dist/51/index.d.ts",
      "import": "./dist/51/index.js"
    },
    "./65": {
      "types": "./dist/65/index.d.ts",
      "import": "./dist/65/index.js"
    },
    "./66": {
      "types": "./dist/66/index.d.ts",
      "import": "./dist/66/index.js"
    },
    "./89": {
      "types": "./dist/89/index.d.ts",
      "import": "./dist/89/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "nostr-tools": ">=2.23.3 <3.0.0"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.0"
  },
  "devDependencies": {
    "nostr-tools": "^2.23.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "cd ../.. && vitest run --config vitest.config.ts packages/nip",
    "test": "pnpm test:unit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kehto/web.git",
    "directory": "packages/nip"
  },
  "keywords": [
    "nostr",
    "nip",
    "nip5a",
    "nip5d",
    "nip51",
    "nip65",
    "nip66",
    "nip89",
    "aggregate-hash",
    "content-addressed",
    "blossom",
    "napplet-resolution",
    "relay-discovery",
    "outbox-model",
    "app-handlers",
    "kehto",
    "napplet"
  ]
}
