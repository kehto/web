{
  "name": "@kehto/nip",
  "version": "0.1.0",
  "description": "Tree-shakable bundle of unique Nostr NIP utilities for napplet runtimes — each NIP at its own subpath (e.g. @kehto/nip/66)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./66": {
      "types": "./dist/66.d.ts",
      "import": "./dist/66.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "nostr-tools": ">=2.23.3 <3.0.0"
  },
  "devDependencies": {
    "nostr-tools": "^2.23.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "cd ../.. && vitest run --config vitest.config.ts packages/nip/src/66.test.ts",
    "test": "pnpm test:unit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kehto/web.git",
    "directory": "packages/nip"
  },
  "keywords": [
    "nostr",
    "nip",
    "nip66",
    "relay-discovery",
    "kehto",
    "napplet"
  ]
}
