{
  "name": "@kehto/services",
  "version": "0.1.0",
  "description": "Reference service implementations for the napplet protocol \u2014 audio, notifications, and extensible service handlers",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
