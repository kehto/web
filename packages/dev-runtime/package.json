{
  "name": "@kehto/dev-runtime",
  "version": "0.1.0",
  "description": "Single-window development runtime for hosting napplets in a real Kehto iframe during local development",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kehto-dev-runtime": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kehto/acl": "workspace:*",
    "@kehto/firewall": "workspace:*",
    "@kehto/nip": "workspace:*",
    "@kehto/runtime": "workspace:*",
    "@kehto/services": "workspace:*",
    "@kehto/shell": "workspace:*",
    "@kehto/wm": "workspace:*"
  },
  "peerDependencies": {
    "@napplet/core": ">=0.12.0 <0.14.0",
    "@napplet/nap": ">=0.12.0 <0.14.0",
    "nostr-tools": ">=2.23.3 <3.0.0"
  },
  "devDependencies": {
    "@napplet/core": "^0.13.0",
    "@napplet/nap": "^0.13.0",
    "nostr-tools": "^2.23.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "cd ../.. && vitest run --config vitest.config.ts packages/dev-runtime",
    "test": "pnpm test:unit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kehto/web.git",
    "directory": "packages/dev-runtime"
  },
  "keywords": [
    "nostr",
    "napplet",
    "kehto",
    "development",
    "runtime",
    "hmr"
  ]
}
