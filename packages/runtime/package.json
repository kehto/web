{
  "name": "@kehto/runtime",
  "version": "0.14.0",
  "description": "Browser-agnostic protocol engine for the napplet protocol — message dispatch, ACL enforcement, AUTH handshake",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kehto/acl": "workspace:^",
    "@kehto/firewall": "workspace:^",
    "@noble/hashes": "^2.0.0",
    "@noble/curves": "^2.0.0"
  },
  "peerDependencies": {
    "@napplet/core": ">=0.20.0 <0.21.0",
    "@napplet/nap": ">=0.20.0 <0.21.0"
  },
  "devDependencies": {
    "@napplet/core": "^0.20.0",
    "@napplet/nap": "^0.20.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "echo 'no unit tests yet'"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kehto/web.git",
    "directory": "packages/runtime"
  },
  "keywords": [
    "nostr",
    "napplet",
    "kehto",
    "runtime",
    "protocol-engine"
  ]
}
