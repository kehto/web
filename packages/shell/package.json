{
  "name": "@kehto/shell",
  "version": "0.16.3",
  "description": "Shell runtime — relay bridge, ACL enforcement, signer proxy, storage proxy for hosting napplet iframe applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kehto/acl": "workspace:^",
    "@kehto/runtime": "workspace:^"
  },
  "peerDependencies": {
    "@napplet/core": ">=0.23.0 <=0.27.x",
    "@napplet/nap": ">=0.23.0 <=0.27.x",
    "nostr-tools": ">=2.23.3 <=2.x"
  },
  "devDependencies": {
    "@napplet/core": ">=0.23.0 <=0.27.x",
    "@napplet/nap": ">=0.23.0 <=0.27.x",
    "@napplet/shim": "^0.26.2",
    "nostr-tools": "^2.23.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "echo 'no unit tests yet'"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kehto/web.git",
    "directory": "packages/shell"
  },
  "keywords": [
    "nostr",
    "napplet",
    "kehto",
    "shell",
    "relay-bridge"
  ]
}
