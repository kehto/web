{
  "name": "@kehto/shell",
  "version": "0.1.0",
  "description": "Shell runtime — relay bridge, ACL enforcement, signer proxy, storage proxy for hosting napplet iframe applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kehto/runtime": "workspace:*"
  },
  "peerDependencies": {
    "@napplet/core": ">=0.1.0",
    "nostr-tools": ">=2.23.3 <3.0.0"
  },
  "devDependencies": {
    "nostr-tools": "^2.23.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test:unit": "echo 'no unit tests yet'"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kehto/runtime.git",
    "directory": "packages/shell"
  },
  "keywords": ["nostr", "napplet", "kehto", "shell", "relay-bridge"]
}
