{
  "name": "kehto",
  "private": true,
  "type": "module",
  "scripts": {
    "audit:csp": "node scripts/audit-csp.mjs",
    "audit:gateway-artifacts": "node scripts/audit-gateway-artifacts.mjs",
    "audit:pages": "node scripts/audit-pages-artifact.mjs",
    "build:pages": "node scripts/build-pages.mjs",
    "build": "turbo run build",
    "build:playground-pages": "node scripts/build-playground-pages.mjs",
    "docs:api": "typedoc",
    "docs:api:strict": "typedoc --treatWarningsAsErrors",
    "docs:site:dev": "pnpm --dir docs docs:dev",
    "docs:site:build": "pnpm docs:api:strict && turbo run docs:build --filter @kehto/docs && node scripts/copy-docs-api.mjs",
    "docs:site:preview": "pnpm --dir docs docs:preview",
    "docs:check": "pnpm docs:site:build && node scripts/audit-docs.mjs",
    "type-check": "turbo run type-check",
    "test": "pnpm build && pnpm test:unit",
    "test:unit": "vitest run",
    "test:e2e": "pnpm test:build && npx playwright test",
    "test:build": "pnpm build",
    "test:serve": "pnpm --filter @test/harness dev",
    "test:serve:demo": "pnpm --filter @kehto/playground preview --port 4174",
    "lint": "turbo run lint",
    "site:build": "VITEPRESS_BASE=/web/docs/ pnpm docs:check && pnpm build:pages",
    "site:dev": "pnpm --filter @kehto/playground exec vite ../../web --host 127.0.0.1 --port 5175 --base /web/",
    "site:preview": "pnpm site:build && node scripts/serve-pages.mjs",
    "site:serve": "node scripts/serve-pages.mjs",
    "version-packages": "changeset version",
    "publish-packages": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.54.0",
    "@vitest/coverage-v8": "^4.1.2",
    "nostr-tools": "^2.23.3",
    "turbo": "^2.9.14",
    "typedoc": "^0.28",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "5.0.6",
      "postcss": "8.5.15",
      "esbuild@<=0.24.2": "^0.25.0",
      "vite@<=6.4.1": "^6.4.2"
    }
  },
  "packageManager": "pnpm@10.8.0",
  "dependencies": {
    "gsap": "^3.15.0"
  }
}
