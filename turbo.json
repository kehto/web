{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:napplets": {
      "dependsOn": ["^build"],
      "outputs": [
        "apps/demo/napplets/*/dist/**",
        "tests/fixtures/napplets/*/dist/**"
      ]
    },
    "@kehto/demo#build": {
      "dependsOn": ["^build", "build:napplets"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:unit": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
